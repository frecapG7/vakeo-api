FROM node:18-alpine as build
WORKDIR /build

# Copy package files
COPY package*.json ./

# Install the dependencies
RUN npm install

# Copy the rest of the application code
COPY . .

# If link-preview-js needs building, this will trigger postinstall scripts
RUN npm rebuild && npm cache clean --force

# Production stage
FROM node:18-alpine
WORKDIR /app

# Copy package files and install production dependencies only
COPY --from=build /build/package*.json ./
RUN npm install --omit=dev

# Copy everything from build stage
COPY --from=build /build ./

# Remove the build-stage node_modules and use our clean production ones
RUN rm -rf ./node_modules && cp -r /app/node_modules ./node_modules

EXPOSE 3000
CMD ["node", "index.mjs"]